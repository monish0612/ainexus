# ═══════════════════════════════════════════════════════
# AI NEXUS — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────
DB_PASSWORD=change_this_to_strong_password

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change_this_to_32_char_minimum_secret

# ── LiteLLM ──────────────────────────────────────────
# Master key: admin access to LiteLLM dashboard + API
LITELLM_MASTER_KEY=sk-litellm-master-CHANGE-THIS

# Virtual key: what your Node.js API uses to call LiteLLM
# Generate after first deploy: POST /key/generate with master key
LITELLM_VIRTUAL_KEY=sk-litellm-app-CHANGE-THIS

# ── LLM Provider API Keys ────────────────────────────
# Both are required — Gemini is primary, Groq is fallback
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ── Search / Grounding ────────────────────────────────
TAVILY_API_KEY=tvly-...
ZYTE_API_KEY=...
# Comma-separated Gemini models for Google Search Grounding (first = primary, rest = fallback)
GROUNDING_MODELS=gemini-3.1-flash-lite-preview

# ── xGrok (xAI Grok — OpenAI-compatible) ─────────────
XGROK_API_KEY=xai-...
XGROK_LITE_MODEL=grok-4-1-fast-non-reasoning
XGROK_DEEP_MODEL=grok-4-0709

# ── Gemini Pro (for deep research / follow-ups) ──────
GEMINI_PRO_MODEL=gemini-3.1-pro-preview

# ── Optional ─────────────────────────────────────────
CORS_ORIGIN=*
NODE_ENV=production
